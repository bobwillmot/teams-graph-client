# Microsoft Graph delegated auth settings for posting to a Teams channel.
# Register a public client app, allow public client flows, and grant delegated
# Microsoft Graph permission ChannelMessage.Send.
MS_TENANT_ID=organizations
MS_CLIENT_ID=https://replace-this-with-your-app-client-id
TEAMS_GRAPH_TEAM_ID=replace-this-with-your-team-id
TEAMS_GRAPH_CHANNEL_ID=replace-this-with-your-channel-id
# Optional: provide a short-lived bearer token instead of interactive sign-in.
MS_GRAPH_ACCESS_TOKEN=